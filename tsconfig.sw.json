{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["WebWorker", "ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "outDir": ".",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["sw.ts"],
  "exclude": ["node_modules", "dist", ".vite"]
}
